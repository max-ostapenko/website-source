{
  "hosting": [
    {
      "target": "max-ostapenko",
      "public": "_site",
      "predeploy": [
        "npm run render"
      ],
      "cleanUrls": true,
      "trailingSlash": true,
      "headers": [
        {
          "source": "**/*.png",
          "headers": [{ "key": "Content-Type", "value": "image/png" }]
        },
        {
          "source": "**/*.svg",
          "headers": [{ "key": "Content-Type", "value": "image/svg+xml" }]
        }
      ]
    }
  ]
}
